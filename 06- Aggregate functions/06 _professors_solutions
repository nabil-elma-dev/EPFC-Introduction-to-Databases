-- EXERCICE 1

-- 1)

SELECT id_p, SUM(weight) FROM p GROUP BY color;

-- La requête est illégale car il y a un champ (id_p) dans la clause SELECT qui
-- n'est pas dans la clause GROUP BY
-- Pour corriger cela, on peut par exemple grouper par id_p :

SELECT id_p, SUM(weight) FROM p GROUP BY id_p;

-- par contre, cela n'a pas beaucoup de sens. Comme id_p est la clé primaire de p,
-- nous sommes en train de construire des groupes qui contiennent tous un seul produit.

-- Une autre solution, est de grouper par couleur et de sélectionner la couleur :

SELECT color, SUM(weight) FROM p GROUP BY color;

-- On obtient donc la somme des poids des produits en fonction de leur couleur.
-- "Pour chaque couleur, afficher la somme des poids des produits".

-- 2)

SELECT id_s, SUM(qty) FROM spj;

-- On ne peut pas utiliser des valeurs qui n'ont pas la même cardinalité dans SELECT.
-- Dans la table SPJ, il y a plusieurs ID_S mais une seule SUM(qty).

-- Pour corriger cela, il faudrait grouper par ID_S pour obtenir la somme des quantités
-- livrées par fournisseur :

SELECT id_s, SUM(qty) FROM spj GROUP BY id_s;

-- 3)

SELECT id_p, weight FROM p GROUP BY id_p;

-- Cette requête, bien que légale dans la norme SQL car utilisant le fait que weight
-- est en dépendance fonctionnelle par rapport à id_p (ce qui veut dire que chaque produit
-- a un poids et que la clé du produit (id_p) détermine de façon univoque son poids),
-- ne sera pas acceptée avec la configuration appliquée en début de TP.
-- Nous appliquons cette configuration pour des raisons pédagogiques (le concept de dépendance
-- fonctionnelle n'est pas vu dans ce cours), et également car d'autres SGBD (comme SQLServer
-- utilisé dans le cours de BDGE) n'accepte pas de telles requêtes.

-- La formulation valide dans notre cours est la suivante :

SELECT id_p, weight FROM p GROUP BY id_p, weight;

-- Cela donne les identifiants des produits et leur poids.
-- Comme pour la question 1, nous sommes en train de construire des groupes qui
-- contiennent tous un seul produit. Il n'est donc pas nécessaire de grouper.
-- La requête suivante donne le même résultat :

SELECT id_p, weight FROM p;


-- EXERCICE 2

-- 1) Déterminez par quantité le nombre de livraisons effectuées
SELECT COUNT(*), qty
FROM spj
GROUP BY qty;

-- 2) On souhaite connaître le nombre de livraisons de chaque fournisseur.
SELECT id_s, COUNT(*)
FROM spj
GROUP BY id_s;

-- 3) On veut connaître le nombre de pièces fournies par projet.
--    On souhaite le nom du projet et non pas son identifiant.
SELECT j.jname, SUM(qty)
FROM spj JOIN j ON j.id_j=spj.id_j
GROUP BY j.id_j, j.jname;
-- ATTENTION : il est important de grouper par j.id_j car il pourrait y avoir
--             plusieurs projets qui ont le même nom. Pas d'hypothèses sur les données !

-- 4) On veut connaître le poids de chaque livraison.
SELECT id_s, spj.id_p, id_j,qty * weight
FROM spj, p
WHERE spj.id_p=p.id_p;
-- Remarque : pas besoin de GROUP BY ici (une ligne par livraison)

-- 5) On veut connaître le poids total des pièces livrées par projet.
SELECT  id_j, SUM(qty * weight)
FROM spj, p
WHERE spj.id_p=p.id_p
GROUP BY id_j;

-- 6) On veut connaître le poids de la livraison la plus lourde.
SELECT MAX(qty*weight)
FROM spj,p
WHERE spj.id_p=p.id_p;
-- Remarque : pas besoin de GROUP BY ici (un résultat pour l'ensemble des livraisons)

-- 7) Pour chaque pièce fournie à un projet, obtenir le numéro de pièce,
--    le numéro de projet et la quantité totale fournie (de cette pièce à ce projet)
--    dont l’intitulé sera « total ».
SELECT id_j, id_p, SUM(qty) total
FROM spj
GROUP BY id_p, id_j;